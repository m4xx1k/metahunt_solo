{
  "name": "metahunt",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl build",
    "start": "pnpm --filter @metahunt/etl start",
    "start:prod": "pnpm --filter @metahunt/etl start:prod",
    "dev": "pnpm --filter @metahunt/database build && pnpm -r --parallel run dev",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node --project tsconfig.json libs/database/migrate.ts",
    "db:seed": "ts-node --project tsconfig.json libs/database/seeds/run.ts",
    "db:studio": "drizzle-kit studio"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
