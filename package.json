{
  "name": "metahunt",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl build",
    "build:web": "pnpm --filter @metahunt/web build",
    "build:all": "pnpm run build && pnpm run build:web",
    "start": "pnpm --filter @metahunt/etl start",
    "start:prod": "pnpm --filter @metahunt/etl start:prod",
    "start:web": "pnpm --filter @metahunt/web start",
    "dev": "pnpm --filter @metahunt/database build && pnpm -r --parallel run dev",
    "dev:etl": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl dev",
    "test:etl": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl test",
    "dev:web": "pnpm --filter @metahunt/web dev",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:restart": "pnpm dev:stop && sleep 1 && pnpm dev",
    "lint:web": "pnpm --filter @metahunt/web lint",
    "lint": "pnpm -r --if-present run lint",
    "format": "prettier --write .",
    "prepare": "husky",
    "test:web": "pnpm --filter @metahunt/web test",
    "docker:infra": "docker compose -f compose.infra.yaml up -d",
    "docker:infra:down": "docker compose -f compose.infra.yaml down",
    "docker:dev": "docker compose -f compose.infra.yaml up -d && docker compose watch",
    "docker:dev:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node --project tsconfig.json libs/database/migrate.ts",
    "db:seed": "ts-node --project tsconfig.json libs/database/seeds/run.ts",
    "db:seed:tracks": "ts-node --project tsconfig.json libs/database/seeds/tracks.run.ts",
    "db:seed:candidates": "ts-node --project tsconfig.json libs/database/seeds/candidates.run.ts",
    "db:seed:cv-tailor": "ts-node --project tsconfig.json libs/database/seeds/cv-tailor.run.ts",
    "db:seed:node-slugs": "ts-node --project tsconfig.json libs/database/seeds/node-slugs.run.ts",
    "db:studio": "drizzle-kit studio",
    "dedup:embed": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl build && node --env-file-if-exists=.env apps/etl/dist/dedup/dedup.cli.js embed",
    "dedup:resolve": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl build && node --env-file-if-exists=.env apps/etl/dist/dedup/dedup.cli.js resolve",
    "dedup:reset": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl build && node --env-file-if-exists=.env apps/etl/dist/dedup/dedup.cli.js reset",
    "skills:classify": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl build && node --env-file-if-exists=.env apps/etl/dist/03-discovery/ranking/classify-skills.cli.js",
    "test:etl:int": "pnpm --filter @metahunt/database build && pnpm --filter @metahunt/etl test:int"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "bash -c 'cd apps/web && pnpm exec eslint --fix \"$@\"' _",
      "bash -c 'cd apps/web && pnpm exec prettier --write \"$@\"' _"
    ],
    "apps/etl/**/*.ts": [
      "bash -c 'cd apps/etl && pnpm exec eslint --fix \"$@\"' _",
      "bash -c 'cd apps/etl && pnpm exec prettier --write \"$@\"' _"
    ],
    "libs/database/**/*.ts": [
      "bash -c 'cd libs/database && pnpm exec eslint --fix \"$@\"' _",
      "bash -c 'cd libs/database && pnpm exec prettier --write \"$@\"' _"
    ],
    "**/*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
