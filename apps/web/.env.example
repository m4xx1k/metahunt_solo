# API base for Server-Component fetchers (lib/api/*). Points at the ETL.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Clerk — operator auth on the (investigation) route group.
# Grab both from https://dashboard.clerk.com (your app → API keys).
# First-time setup: see md/runbook/clerk-auth.md.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# PostHog (client-side). Leave empty to keep analytics dormant in local dev.
# Use the project's Project API Key. Events route through the /ingest reverse
# proxy (next.config.ts) to dodge ad blockers — the PostHog region lives there,
# not here. EU project assumed; flip the hosts in next.config.ts for US.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
