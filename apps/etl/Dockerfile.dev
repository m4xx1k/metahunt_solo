# Dev image for @metahunt/etl (NestJS). Installs only etl + the database lib it
# imports; runs as the non-root `node` user. `docker compose watch` syncs edits
# in and rebuilds on dependency changes. Build context is the repo root (the
# pnpm workspace); the repo-root .dockerignore already excludes apps/web.
FROM node:22-slim

# ca-certificates: @temporalio/core-bridge reads the OS trust store (prod parity).
# git: some tooling shells out to it. Then create an app dir owned by `node` so
# the whole build runs unprivileged (no slow chown -R afterwards).
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates git \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g pnpm@10 \
 && mkdir -p /app && chown node:node /app

USER node
WORKDIR /app

# Manifests only → cached install layer. Only etl + database are copied, so the
# workspace resolves to those two (as in the prod Dockerfile).
COPY --chown=node:node package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json tsconfig.base.json drizzle.config.ts ./
COPY --chown=node:node apps/etl/package.json apps/etl/package.json
COPY --chown=node:node libs/database/package.json libs/database/package.json
RUN pnpm install -r --frozen-lockfile

COPY --chown=node:node . .
RUN pnpm --filter @metahunt/database build

ENV NODE_ENV=development
CMD ["pnpm", "--filter", "@metahunt/etl", "dev"]
