{
  "name": "@metahunt/etl",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node --env-file-if-exists=../../.env dist/main.js",
    "start:prod": "node --env-file-if-exists=../../.env dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "dev": "nest start --watch",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "baml:generate": "baml-cli generate --from baml_src",
    "baml:check": "baml-cli check --from baml_src",
    "test:int": "jest --config jest.int.config.ts --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@boundaryml/baml": "^0.222.0",
    "@metahunt/database": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@temporalio/activity": "^1.16.1",
    "@temporalio/client": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^4.5.0",
    "grammy": "^1.43.0",
    "nestjs-temporal-core": "^3.2.7",
    "posthog-node": "^5.35.13",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "unpdf": "^1.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "aws-sdk-client-mock": "^4.1.0",
    "jest": "^29.7.0",
    "pg": "^8.20.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.0"
  }
}
