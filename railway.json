{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "Dockerfile",
      "railway.json",
      "package.json",
      "pnpm-lock.yaml",
      "apps/etl/**",
      "libs/**"
    ]
  },
  "deploy": {
    "preDeployCommand": "node -r ts-node/register/transpile-only libs/database/migrate.ts",
    "startCommand": "node apps/etl/dist/main.js",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
