# NODE_ENV=local forces Temporal to the docker-compose stack (localhost:7233, namespace=default)
# regardless of TEMPORAL_* values below — useful when you keep Cloud creds in .env but want
# local dev disconnected from Cloud (otherwise local + Railway workers split-brain on the same queue).
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://metahunt:metahunt@localhost:54322/metahunt

# Temporal
# Local dev: leave TEMPORAL_API_KEY empty; plaintext to localhost:7233.
# Temporal Cloud (API-key mode): set TEMPORAL_API_KEY → TLS enabled automatically.
#   - TEMPORAL_ADDRESS = "<namespace>.<account-id>.tmprl.cloud:7233"
#   - TEMPORAL_NAMESPACE = "<namespace>.<account-id>"
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=rss-ingest
TEMPORAL_API_KEY=

# RSS ingest schedule cadence in hours (1..16). The Temporal Schedule fires
# every N hours from 06:00 to 22:00 Europe/Kyiv, daily. (Re)installed on app
# boot — change this value and restart to apply.
RSS_INGEST_INTERVAL_HOURS=1

# S3-compatible storage (MinIO locally)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=rss-payloads
STORAGE_ACCESS_KEY=metahunt
STORAGE_SECRET_KEY=metahunt123
STORAGE_REGION=us-east-1

# AI extraction
# EXTRACTOR_PROVIDER selects the VacancyExtractor implementation:
#   placeholder — static stub, no LLM call (default; used in tests)
#   baml        — BAML-typed client; extraction routes through DeepSeek's official
#                 API (apps/etl/baml_src/clients.baml → DeepSeekClient).
# DEEPSEEK_API_KEY is required when EXTRACTOR_PROVIDER=baml. DEEPSEEK_MODEL keys
# the extraction_cost view's per-model pricing — keep it in sync with pricing.ts.
EXTRACTOR_PROVIDER=placeholder
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# OpenAI is retained for the dedup confirm-tier (gpt-5-nano); unused by extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
# BAML logging: OFF | ERROR | WARN | INFO | DEBUG | TRACE. Default INFO logs
# every call (prompt + raw response); even WARN dumps the full prompt on parse
# errors. We set OFF in prod to stay under Railway's log quota — the extractor
# wrapper still re-throws a one-line error so Temporal records the failure
# reason. Flip to DEBUG locally when you need to see prompt drift.
BAML_LOG=OFF

# Analytics (PostHog, server-side). Leave POSTHOG_API_KEY empty to keep the
# AnalyticsService dormant — it logs a warning and no-ops every event, so local
# and CI ship nothing. POSTHOG_HOST defaults to PostHog EU. Use the project's
# Project API Key (not a personal key).
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
