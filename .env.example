# NODE_ENV=local forces Temporal to the docker-compose stack (localhost:7233, namespace=default)
# regardless of TEMPORAL_* values below — useful when you keep Cloud creds in .env but want
# local dev disconnected from Cloud (otherwise local + Railway workers split-brain on the same queue).
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://metahunt:metahunt@localhost:54322/metahunt

# Temporal
# Local dev: leave TEMPORAL_API_KEY empty; plaintext to localhost:7233.
# Temporal Cloud (API-key mode): set TEMPORAL_API_KEY → TLS enabled automatically.
#   - TEMPORAL_ADDRESS = "<namespace>.<account-id>.tmprl.cloud:7233"
#   - TEMPORAL_NAMESPACE = "<namespace>.<account-id>"
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=rss-ingest
TEMPORAL_API_KEY=

# S3-compatible storage (MinIO locally)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=rss-payloads
STORAGE_ACCESS_KEY=metahunt
STORAGE_SECRET_KEY=metahunt123
STORAGE_REGION=us-east-1

# AI extraction
# EXTRACTOR_PROVIDER selects the VacancyExtractor implementation:
#   placeholder — static stub, no LLM call (default; used in tests)
#   baml        — BAML-typed client over OpenAI (apps/etl/baml_src/extract-vacancy.baml)
# OPENAI_API_KEY is required when EXTRACTOR_PROVIDER=baml (BAML routes through OpenAI).
EXTRACTOR_PROVIDER=placeholder
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# BAML logging: OFF | ERROR | WARN | INFO | DEBUG | TRACE. Default INFO logs every call;
# WARN keeps errors only.
BAML_LOG=WARN
